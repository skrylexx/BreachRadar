# ─── Environnement & secrets ────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ─── Frontend ───────────────────────────────────────────────────────────────
frontend/node_modules
frontend/.next/

# ─── Environnements virtuels ─────────────────────────────────────────────────
.venv/
venv/
env/
.uv/

# ─── Rapports générés (contiennent des données sensibles) ───────────────────
reports/*.json
reports/*.md
reports/*.html
reports/*.pdf
reports/*.txt
# Conserver uniquement le .gitkeep
!reports/.gitkeep

# ─── Sessions Telegram (contiennent des tokens d'authentification) ───────────
*.session
*.session-journal

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Tests & couverture ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker ──────────────────────────────────────────────────────────────────
# Ne pas ignorer docker-compose.yml (il est versionné)
# Les volumes Docker sont gérés par Docker lui-même

# ─── Données locales RansomLook (volumes Docker) ─────────────────────────────
# Ces données sont dans les volumes Docker, pas dans le repo
ransomlook_data/

# Données d'audit de sécurité
security_audits/reports/
