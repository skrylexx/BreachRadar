# ─── BreachRadar WebUI — Variables d'environnement ──────────────────────────
# Copier ce fichier en .env et remplir les valeurs avant le démarrage

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
UI_DB_NAME=breachradar_ui
UI_DB_USER=br_ui
UI_DB_PASSWORD=CHANGE_ME_strong_db_password_here

# ─── Redis (sessions + rate limiting) ────────────────────────────────────────
UI_REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ─── JWT (générer avec : openssl rand -hex 32) ───────────────────────────────
UI_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_minimum_32_chars

# ─── Administrateur initial (créé au premier démarrage) ───────────────────────
UI_ADMIN_EMAIL=admin@yourdomain.com
# Minimum 16 caractères, 1 majuscule, 1 chiffre, 1 caractère spécial
UI_ADMIN_PASSWORD=CHANGE_ME_AdminPassword1!

# ─── SMTP (optionnel — pour reset password et notifications) ─────────────────
UI_SMTP_HOST=smtp.yourdomain.com
UI_SMTP_PORT=587
UI_SMTP_USER=notifications@yourdomain.com
UI_SMTP_PASSWORD=CHANGE_ME_smtp_password
UI_SMTP_FROM_EMAIL=breachradar@yourdomain.com

# ─── Frontend Next.js ─────────────────────────────────────────────────────────
# URL de l'API FastAPI — depuis le navigateur (client-side)
NEXT_PUBLIC_API_URL=http://localhost:8000
