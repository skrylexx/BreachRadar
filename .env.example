# ─── Domaine cible (OBLIGATOIRE) ─────────────────────────────────────────────
# Le domaine à surveiller — doit vous appartenir
TARGET_DOMAIN=mondomaine.fr

# ─── Clés API — Sources gratuites ────────────────────────────────────────────

# HaveIBeenPwned (https://haveibeenpwned.com/API/Key)
# ~3,50 USD/mois pour la recherche email | ~550 USD/an pour Domain Search
HIBP_API_KEY=

# GitHub Personal Access Token (https://github.com/settings/tokens/new)
# Scopes requis : public_repo (lecture seule) | Rate limit : 5000 req/h
GITHUB_TOKEN=

# GitLab Personal Access Token (https://gitlab.com/-/user_settings/personal_access_tokens)
# Scopes requis : read_api
GITLAB_TOKEN=

# URLScan.io (https://urlscan.io/user/signup) — Gratuit
# Détection de pages de phishing imitant votre domaine
URLSCAN_API_KEY=

# AlienVault OTX (https://otx.alienvault.com/accounts/register) — Gratuit
# Indicateurs de compromission liés au domaine
OTX_API_KEY=

# ─── Clés API — Sources payantes recommandées ────────────────────────────────

# LeakCheck.io (https://leakcheck.io/api)
# Plans : Free (10 req/jour), Basic (~10 USD/mois), Pro (~50 USD/mois)
LEAKCHECK_API_KEY=

# Dehashed (https://www.dehashed.com/register)
# Plans : ~5,49 USD/mois (personal) à ~179,99 USD/mois (enterprise)
# L'API utilise Basic Auth : email:api_key en base64
DEHASHED_EMAIL=
DEHASHED_API_KEY=

# Intelligence X / IntelX (https://intelx.io/account?tab=developer)
# Plans : Free (très limité), Developer (~100 EUR/mois)
INTELX_API_KEY=

# Shodan (https://account.shodan.io/) — Plan Member ~65 USD (one-time)
SHODAN_API_KEY=

# ─── Telegram — Monitoring canaux publics uniquement ─────────────────────────
# (https://my.telegram.org/apps) — Usage : canaux PUBLICS uniquement
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── RansomLook — Configuration (OBLIGATOIRE) ────────────────────────────────
# URL de l'instance Docker locale (ne pas modifier si docker-compose standard)
# En mode Docker inter-container : http://ransomlook-app:8888
# En mode local (hors Docker) : http://localhost:8888
RANSOMLOOK_URL=http://localhost:8888

# Termes de recherche supplémentaires (domaine cible toujours inclus automatiquement)
# Séparés par des virgules — inclure noms commerciaux, filiales, acronymes
# Exemple : RANSOMLOOK_SEARCH_TERMS=MonDomaine,Mon Domaine SA,MDomaine,MD Group
RANSOMLOOK_SEARCH_TERMS=

# Email de notification d'urgence si le domaine est détecté sur RansomLook
# (alerte déclenchée IMMÉDIATEMENT, sans attendre la fin du scan)
RANSOMLOOK_ALERT_EMAIL=
RANSOMLOOK_ALERT_WEBHOOK=

# ─── Configuration des rapports ──────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
# Formats disponibles : markdown, json, html, pdf (pdf requiert weasyprint)
REPORT_FORMAT=markdown,json

# ─── Scheduling ──────────────────────────────────────────────────────────────
SCHEDULE_ENABLED=false
# Expression cron standard (exemple : tous les lundis à 8h)
SCHEDULE_CRON=0 8 * * 1

# ─── Proxy (optionnel) ───────────────────────────────────────────────────────
# Pour cloisonner les requêtes OSINT si nécessaire
HTTP_PROXY=
HTTPS_PROXY=

# ─── Logging ─────────────────────────────────────────────────────────────────
# Niveaux : DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
