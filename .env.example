# ─── Moteur BreachRadar : Domaine cible (OBLIGATOIRE) ────────────────────────
TARGET_DOMAIN=example.com

# ─── WebUI : Base de données PostgreSQL ──────────────────────────────────────
UI_DB_NAME=breachradar_ui
UI_DB_USER=br_ui
UI_DB_PASSWORD=CHANGE_ME_strong_db_password_here

# ─── WebUI : Redis (sessions + rate limiting) ────────────────────────────────
UI_REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ─── WebUI : JWT (générer avec : openssl rand -hex 32) ───────────────────────
UI_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_minimum_32_chars

# ─── WebUI : Administrateur initial (créé au premier démarrage) ──────────────
UI_ADMIN_EMAIL=admin@yourdomain.com
UI_ADMIN_PASSWORD=CHANGE_ME_AdminPassword1!

# ─── WebUI : SMTP (notifications et alertes) ─────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM_EMAIL=breachradar@yourdomain.com

# ─── WebUI : Frontend Next.js ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Moteur BreachRadar : Clés API — Sources gratuites ───────────────────────
HIBP_API_KEY=
GITHUB_TOKEN=
GITLAB_TOKEN=
URLSCAN_API_KEY=
OTX_API_KEY=

# ─── Moteur BreachRadar : Clés API — Sources payantes ────────────────────────
LEAKCHECK_API_KEY=
DEHASHED_EMAIL=
DEHASHED_API_KEY=
INTELX_API_KEY=
SHODAN_API_KEY=
HUNTER_API_KEY=

# ─── Moteur BreachRadar : Telegram ───────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── Moteur BreachRadar : RansomLook (mode local ou SaaS) ────────────────────
# Mode d'utilisation : "local" (instance Docker) ou "saas" (https://www.ransomlook.io)
RANSOMLOOK_MODE=local

# Instance locale (Docker) — par défaut
RANSOMLOOK_LOCAL_URL=http://ransomlook-app:8888

# Instance SaaS (hébergée, nécessite une clé d'API fournie dans le compte RansomLook)
RANSOMLOOK_SAAS_API_URL=https://www.ransomlook.io/api
RANSOMLOOK_SAAS_API_KEY=

# Termes de recherche supplémentaires (séparés par des virgules)
RANSOMLOOK_SEARCH_TERMS=

# Notifications en cas d'alerte RansomLook
RANSOMLOOK_ALERT_EMAIL=
RANSOMLOOK_ALERT_WEBHOOK=

# ─── Moteur BreachRadar : Rapports ───────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=markdown,json

# ─── Moteur BreachRadar : Scheduling ─────────────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 8 * * 1

# ─── Proxy & Logging ─────────────────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
LOG_LEVEL=INFO
