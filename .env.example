# ─── NETWORK / HOSTS & PORTS ─────────────────────────────────────────────────
# WebUI local address (Next.js frontend)
UI_HOST=127.0.0.1
UI_PORT=3000

# Backend API local address (FastAPI)
API_HOST=127.0.0.1
API_PORT=8000

# RansomLook instance local address (local mode)
RANSOMLOOK_HOST=127.0.0.1
RANSOMLOOK_PORT=8888

# Public API URL exposed to the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS — allowed origins for the backend API
CORS_ORIGINS=["http://localhost:3000"]

# ─── BreachRadar Engine: Target Domain (REQUIRED) ────────────────────────
# Domain monitored by the OSINT engine (backend + CLI)
TARGET_DOMAIN=example.com

# ─── Demonstration Mode (Mock Data) ──────────────────────────────────────────
# Enables fake data at startup (handy for screenshots/demos)
MOCK_MODE=false

# ─── WebUI: PostgreSQL Database ──────────────────────────────────────
UI_DB_NAME=breachradar_ui
UI_DB_USER=br_ui
UI_DB_PASSWORD=CHANGE_ME_strong_db_password_here

# ─── WebUI: Redis (sessions + rate limiting) ────────────────────────────────
UI_REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ─── WebUI: JWT (generate with: openssl rand -hex 32) ───────────────────────
UI_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_minimum_32_chars

# ─── WebUI: Initial Administrator (created on first startup) ──────────────
UI_ADMIN_EMAIL=admin@yourdomain.com
UI_ADMIN_PASSWORD=CHANGE_ME_AdminPassword1!

# Initial admin for the backend API (if undefined, defaults to UI_ADMIN_* values)
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_AdminPassword1!

# ─── WebUI: SMTP (notifications and alerts) ─────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM_EMAIL=breachradar@yourdomain.com

# ─── BreachRadar Engine: API Keys — Free Sources ───────────────────────
HIBP_API_KEY=
GITHUB_TOKEN=
GITLAB_TOKEN=
URLSCAN_API_KEY=
OTX_API_KEY=

# ─── BreachRadar Engine: API Keys — Paid Sources ────────────────────────
LEAKCHECK_API_KEY=
DEHASHED_EMAIL=
DEHASHED_API_KEY=
INTELX_API_KEY=
SHODAN_API_KEY=
HUNTER_API_KEY=

# ─── BreachRadar Engine: Telegram ───────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── BreachRadar Engine: RansomLook (local or SaaS mode) ────────────────────
# Usage mode: "local" (Docker instance) or "saas" (https://www.ransomlook.io)
RANSOMLOOK_MODE=local

# Local instance (Docker) — default
RANSOMLOOK_LOCAL_URL=http://ransomlook-app:8888

# SaaS instance (hosted, requires an API key provided in your RansomLook account)
RANSOMLOOK_SAAS_API_URL=https://www.ransomlook.io/api
RANSOMLOOK_SAAS_API_KEY=

# Additional search terms used in RansomLook in addition to TARGET_DOMAIN
# Example: RANSOMLOOK_SEARCH_TERMS=ACME,ACME GROUP,ACME EUROPE
RANSOMLOOK_SEARCH_TERMS=

# Notifications for RansomLook alerts
RANSOMLOOK_ALERT_EMAIL=
RANSOMLOOK_ALERT_WEBHOOK=

# ─── BreachRadar Engine: Reports ───────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=markdown,json

# ─── BreachRadar Engine: Scheduling ─────────────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 8 * * 1

# ─── CVE & Vulnerability Intelligence (NVD API 2.0) ───────────────────────────────
# Optional API key for the NVD (NIST National Vulnerability Database).
# Without key: 5 requests / 30 seconds (sufficient for normal use).
# With key: 50 requests / 30 seconds (recommended if polling frequently).
# Get a free key: https://nvd.nist.gov/developers/request-an-api-key
CVE_NVD_API_KEY=

# ─── Proxy & Logging ─────────────────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
LOG_LEVEL=INFO
